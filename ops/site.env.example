# Copy this file to ~/.config/darwin/site.env and fill only the values you have.
# The static-site publish path auto-loads that local file and keeps it out of git.

# Base.dev verification
export DARWIN_BASE_APP_ID=""

# Base lane attribution
export DARWIN_BASE_BUILDER_CODE=""
export DARWIN_BASE_PAYMASTER_SERVICE_URL=""

# Arbitrum lane attribution
export DARWIN_ARBITRUM_BUILDER_CODE=""
export DARWIN_ARBITRUM_PAYMASTER_SERVICE_URL=""

# Optional publish-time local read RPCs. These are only used when the local
# endpoint matches the lane chain ID.
# export DARWIN_BASE_SEPOLIA_LOCAL_RPC_URL="http://127.0.0.1:8545"
# export DARWIN_ARBITRUM_SEPOLIA_LOCAL_RPC_URL="http://127.0.0.1:8547"
