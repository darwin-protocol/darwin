# DARWIN Base Sepolia deployment environment
# Copy this file to a local untracked env file and fill in real values.
# Do not commit secrets.

export ALCHEMY_API_KEY="..."
# Optional override. If omitted and ALCHEMY_API_KEY is set, DARWIN derives the
# Base Sepolia and Ethereum Sepolia RPC URLs automatically.
# export BASE_SEPOLIA_RPC_URL="https://base-sepolia.g.alchemy.com/v2/$ALCHEMY_API_KEY"
export DARWIN_DEPLOYER_PRIVATE_KEY="0x..."
# Optional if you want read-only preflight checks without a private key:
# export DARWIN_DEPLOYER_ADDRESS="0x..."

# Governance and operator roles
export DARWIN_GOVERNANCE="0x..."
export DARWIN_EPOCH_OPERATOR="0x..."
export DARWIN_SAFE_MODE_AUTHORITY="0x..."

# Default alpha testnet bond asset: official Base Sepolia WETH9
export DARWIN_BOND_ASSET="0x4200000000000000000000000000000000000006"

# Optional fallback if you intentionally want a mock bond asset instead
# export DARWIN_DEPLOY_BOND_ASSET_MOCK="1"

# Optional DRW alpha genesis. Only enable this once the core deployment exists
# and you intentionally want to deploy the DRW token + staking stack.
# export DARWIN_DRW_TOTAL_SUPPLY="1000000000000000000000000000"
# export DARWIN_DRW_TREASURY_RECIPIENT="$DARWIN_GOVERNANCE"
# export DARWIN_DRW_INSURANCE_RECIPIENT="$DARWIN_GOVERNANCE"
# export DARWIN_DRW_SPONSOR_REWARDS_RECIPIENT="$DARWIN_GOVERNANCE"
# export DARWIN_DRW_COMMUNITY_RECIPIENT="$DARWIN_GOVERNANCE"
# export DARWIN_DRW_TREASURY_BPS="2000"
# export DARWIN_DRW_INSURANCE_BPS="2000"
# export DARWIN_DRW_SPONSOR_REWARDS_BPS="1000"
# export DARWIN_DRW_STAKING_BPS="3000"
# export DARWIN_DRW_COMMUNITY_BPS="2000"
# export DARWIN_DRW_STAKING_DURATION="31536000"

# Optional overrides
export DARWIN_MIN_BASE_ETH_WEI="10000000000000000"
# export DARWIN_DEPLOYMENT_FILE="$PWD/ops/deployments/base-sepolia.json"
# export DARWIN_STATE_ROOT="$PWD/ops/state/base-sepolia-canary"
# export DARWIN_WATCHER_ARCHIVE_URL="http://127.0.0.1:9447"
# export DARWIN_WATCHER_POLL_SEC="60"
# export DARWIN_FINALIZER_POLL_SEC="60"
