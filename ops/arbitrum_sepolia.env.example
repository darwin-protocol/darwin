export ARBITRUM_SEPOLIA_RPC_URL="https://sepolia-rollup.arbitrum.io/rpc"
# Optional publish-time local read path. Only set this if the local node really
# serves Arbitrum Sepolia and should be preferred for local exporters.
# export DARWIN_ARBITRUM_SEPOLIA_LOCAL_RPC_URL="http://127.0.0.1:8547"
export SEPOLIA_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# Local-only signer material. Keep this file out of git.
export DARWIN_DEPLOYER_ADDRESS="0x..."
export DARWIN_DEPLOYER_PRIVATE_KEY="0x..."
export DARWIN_GOVERNANCE="0x..."
export DARWIN_EPOCH_OPERATOR="0x..."
export DARWIN_SAFE_MODE_AUTHORITY="0x..."

# Arbitrum Sepolia defaults.
export DARWIN_NETWORK="arbitrum-sepolia"
export DARWIN_EXPECT_CHAIN_ID="421614"
export DARWIN_DEPLOYMENT_FILE="ops/deployments/arbitrum-sepolia.json"

# Use a mock bond asset for the first Arbitrum Sepolia DARWIN core deployment.
export DARWIN_DEPLOY_BOND_ASSET_MOCK="1"
